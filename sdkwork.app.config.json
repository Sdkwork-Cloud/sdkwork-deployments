{
  "schemaVersion": 3,
  "kind": "sdkwork.app",
  "app": {
    "key": "sdkwork-deploy",
    "name": "SDKWork Deploy",
    "displayName": "SDKWork Deploy",
    "description": "SDKWork Deploy Web Server control plane for domains, certificates, Nginx-compatible configuration, and application deployment orchestration.",
    "vendor": "SDKWork",
    "officialWebsiteUrl": "https://sdkwork.com/apps/sdkwork-deploy",
    "supportUrl": "https://sdkwork.com/support",
    "privacyPolicyUrl": "https://sdkwork.com/privacy",
    "termsOfServiceUrl": "https://sdkwork.com/terms",
    "iconUrl": "https://cdn.sdkwork.com/apps/sdkwork-deploy/assets/icon-1024.png",
    "appType": "SDK",
    "versionSource": "manifest",
    "identifiers": {
      "packageName": null,
      "bundleId": null,
      "desktopAppId": null,
      "containerImage": "registry.sdkwork.com/apps/sdkwork-deploy"
    }
  },
  "backend": {
    "profileKey": "backend-root-admin",
    "ownerMode": "tenant",
    "grantMode": "current",
    "platform": "API",
    "appId": null,
    "tenantId": "100001",
    "organizationId": "0"
  },
  "runtime": {
    "family": "server",
    "framework": "rust-service",
    "runtimes": [
      "API"
    ],
    "deliveryModes": [
      "CONTAINER_IMAGE"
    ],
    "defaultPlatform": "API",
    "defaultArchitecture": "x64",
    "deploymentProfile": "cloud",
    "runtimeTarget": "server",
    "supportedDeploymentProfiles": [
      "standalone",
      "cloud"
    ]
  },
  "publish": {
    "status": "ACTIVE",
    "platforms": [
      "API"
    ],
    "installPlatforms": [
      "API"
    ],
    "defaultPackageId": "linux-x64-cloud-server-tar-gz",
    "storeUrl": "https://sdkwork.com/apps/sdkwork-deploy",
    "config": {
      "workspaceRoot": "sdkwork-deployments",
      "framework": "rust-service"
    }
  },
  "release": {
    "defaultVersion": "0.1.0",
    "notes": [
      {
        "version": "0.1.0",
        "title": "Initial standards-aligned bootstrap",
        "body": "Bootstrap SDKWork Deploy repository with web-framework, database framework, and utils integration."
      }
    ]
  },
  "apiSurfaces": [
    {
      "id": "sdkwork-deploy-app-api",
      "kind": "app-api",
      "apiPrefix": "/app/v3/api",
      "authority": "apis/app-api/deploy/openapi.yaml"
    },
    {
      "id": "sdkwork-deploy-backend-api",
      "kind": "backend-api",
      "apiPrefix": "/backend/v3/api",
      "authority": "apis/backend-api/deploy/openapi.yaml"
    }
  ],
  "sdkFamilies": [],
  "sdkDependencies": [
    {
      "family": "sdkwork-appbase-app-sdk",
      "reason": "IAM login/session and tenant request context for protected app-api routes."
    },
    {
      "family": "sdkwork-appbase-backend-sdk",
      "reason": "Platform operator IAM for protected backend-api routes."
    },
    {
      "family": "sdkwork-drive-app-sdk",
      "reason": "Drive-backed package upload lifecycle for deployment artifacts."
    }
  ],
  "dependencyApiExports": [],
  "dependencyApiSurfaces": []
}
