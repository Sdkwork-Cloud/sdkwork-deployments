SDKWORK_DEPLOY_DEPLOYMENT_PROFILE=cloud
SDKWORK_DEPLOY_SERVICE_LAYOUT=unified-process
SDKWORK_DEPLOY_ENVIRONMENT=development
SDKWORK_DEPLOY_PROFILE_ID=cloud.unified-process.development
SDKWORK_DEPLOY_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:3900
SDKWORK_DEPLOY_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:3900
SDKWORK_DEPLOY_APPLICATION_APP_HTTP_BIND=127.0.0.1:3900
SDKWORK_DEPLOY_APPLICATION_APP_HTTP_URL=http://127.0.0.1:3900/app/v3/api
SDKWORK_DEPLOY_APPLICATION_BACKEND_HTTP_BIND=127.0.0.1:3900
SDKWORK_DEPLOY_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:3900/backend/v3/api
SDKWORK_DEPLOY_DATABASE_ENGINE=sqlite
SDKWORK_DEPLOY_DATABASE_URL=sqlite://./.sdkwork/local/deploy-development.db
SDKWORK_DEPLOY_DATABASE_AUTO_MIGRATE=true
SDKWORK_DEPLOY_DEV_AUTH_BYPASS=true
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.deployments.development.toml
